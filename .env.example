# Django
SECRET_KEY=changeme-generate-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Asia/Tashkent

# Database (defaults to sqlite if unset)
# DATABASE_URL=postgres://aiplatforma:aiplatforma123@localhost:5432/aiplatforma
# DATABASE_URL=sqlite:///db.sqlite3

# --- Docker/server rejimi uchun (docker compose up) ---
# Konteynerlarda host nomlari xizmat nomlariga teng: db, redis
# DATABASE_URL=postgres://aiplatforma:aiplatforma123@db:5432/aiplatforma
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
# SECURE_SSL_REDIRECT=False   # HTTPS sozlanmaguncha False, aks holda redirect-loop
# POSTGRES_DB=aiplatforma
# POSTGRES_USER=aiplatforma
# POSTGRES_PASSWORD=kuchli-parol-qoying

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Email (SMTP) — leave blank to use the console backend in dev
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@aiplatforma.local

FRONTEND_URL=http://localhost:8000

# AI agents — one key is enough. Gemini is used when GEMINI_API_KEY is set,
# otherwise Claude via ANTHROPIC_API_KEY. Force with AI_PROVIDER=gemini|anthropic.
# Free Gemini key: https://aistudio.google.com | Claude: https://console.anthropic.com
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
