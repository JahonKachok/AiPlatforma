SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
